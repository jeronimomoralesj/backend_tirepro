// =============================================================================
// TIRE MASTER CATALOG
// 2,592 SKUs from the Colombian & Latin American market.
// Used by the analysis engine to:
//   • Validate application match (tire design vs axle)
//   • Look up recommended PSI, expected km, retreadability
//   • Provide CPK benchmarks and replacement suggestions
//   • Auto-fill tire specs when a new tire is registered
// =============================================================================

model TireMasterCatalog {
  id             String   @id @default(uuid())

  // Identity
  marca          String
  modelo         String   // design/band name
  dimension      String
  skuRef         String   @unique  // unique SKU reference

  // Dimensional breakdown
  anchoMm        Float?   // tire width in mm
  perfil         String?  // aspect ratio (e.g., "70", "80", "R")
  rin            String?  // rim size (e.g., "22.5", "20")

  // Application
  posicion       String?  // D=Steer, T=Drive, AP=AllPosition, R=Trailer
  ejeTirePro     EjeType? // mapped axle type for TirePro
  terreno        String?  // Carretera, Mixto, Urbano, Off-Road
  pctPavimento   Int      @default(100)  // % paved road suitability
  pctDestapado   Int      @default(0)    // % unpaved road suitability

  // Performance specs
  rtdMm          Float?   // initial tread depth (mm)
  indiceCarga    String?  // load index
  indiceVelocidad String? // speed rating
  psiRecomendado Float?   // recommended pressure (PSI)
  pesoKg         Float?   // tire weight

  // Expected life
  kmEstimadosReales   Int?    // realistic km estimate for Colombia
  kmEstimadosFabrica  Int?    // manufacturer's km estimate

  // Retread info
  reencauchable       Boolean @default(false)
  vidasReencauche     Int     @default(0) // max number of retreads

  // Financial
  precioCop           Float?  // retail price in COP
  cpkEstimado         Float?  // computed: precioCop / kmEstimadosReales

  // Classification
  categoria           String? // "nueva" | "reencauche" — distinguishes new tires from retread bands
  segmento            String? // "Tractomula | Bus_Interurbano"
  tipo                String? // Radial, Convencional
  construccion        String? // Acero, Nylon, etc.

  // Notes & source
  notasColombia       String? @db.Text
  fuente              String?
  url                 String?

  // ─── CROWDSOURCE INTELLIGENCE ────────────────────────────────────
  // Populated when SKU is created/enriched from user-submitted tire data.
  // fuente = "crowdsource" marks these entries.
  crowdSampleSize         Int       @default(0)    // total tires contributing data
  crowdCompanyCount       Int       @default(0)    // distinct companies (privacy: ≥3 to publish)
  crowdAvgPrice           Float?    // trimmed mean price COP
  crowdMedianPrice        Float?    // median price COP
  crowdStddevPrice        Float?    // price stddev — measures market spread
  crowdP25Price           Float?    // 25th percentile
  crowdP75Price           Float?    // 75th percentile
  crowdAvgInitialDepth    Float?    // trimmed mean initial depth mm
  crowdMedianInitialDepth Float?    // median initial depth mm
  crowdStddevDepth        Float?    // depth stddev
  crowdAvgKm              Int?      // average km per vida from real data
  crowdMedianKm           Int?      // median km per vida
  crowdAvgCpk             Float?    // average CPK across all contributing tires
  crowdMedianCpk          Float?    // median CPK
  crowdAvgWearRate        Float?    // mm per 1000km average wear rate
  crowdConfidence         Float?    // 0–1 confidence score based on sample size + spread
  crowdLastUpdated        DateTime? // last time crowd stats were recalculated

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([marca, dimension])
  @@index([dimension])
  @@index([marca, modelo])
  @@index([ejeTirePro])
  @@index([terreno])
  @@index([dimension, ejeTirePro])
  @@index([cpkEstimado])
  @@index([fuente])
  @@index([categoria])
  @@map("tire_master_catalog")

  listings DistributorListing[]
}

// =============================================================================
// MARKETPLACE — Bid System + Ecommerce Listings
// =============================================================================

model BidRequest {
  id              String           @id @default(uuid())
  companyId       String
  status          BidRequestStatus @default(abierta)

  items           Json             // [{tireId?, marca, dimension, diseno, eje, cantidad, tipo:"nueva"|"reencauche", catalogId?}]
  totalEstimado   Float?
  notas           String?          @db.Text
  deliveryAddress String?

  deadline        DateTime?
  maxBidders      Int              @default(10)
  isPublic        Boolean          @default(false)

  winnerId        String?
  resolvedAt      DateTime?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  company         Company          @relation("CompanyBidRequests", fields: [companyId], references: [id])
  winner          Company?         @relation("WonBids", fields: [winnerId], references: [id])
  responses       BidResponse[]
  invitations     BidInvitation[]

  @@index([companyId, status])
  @@index([status, isPublic])
  @@index([deadline])
  @@index([createdAt])
  @@map("bid_requests")
}

model BidInvitation {
  id              String   @id @default(uuid())
  bidRequestId    String
  distributorId   String
  sentAt          DateTime @default(now())

  bidRequest      BidRequest @relation(fields: [bidRequestId], references: [id], onDelete: Cascade)
  distributor     Company    @relation("BidInvitations", fields: [distributorId], references: [id])

  @@unique([bidRequestId, distributorId])
  @@index([distributorId])
  @@map("bid_invitations")
}

model BidResponse {
  id              String            @id @default(uuid())
  bidRequestId    String
  distributorId   String
  status          BidResponseStatus @default(pendiente)

  cotizacion      Json?             // [{itemIndex, precioUnitario, disponible, tiempoEntrega, notas, catalogId?}]
  totalCotizado   Float?
  notas           String?           @db.Text
  incluyeIva      Boolean           @default(false)
  tiempoEntrega   String?

  submittedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  bidRequest      BidRequest @relation(fields: [bidRequestId], references: [id], onDelete: Cascade)
  distributor     Company    @relation("BidResponses", fields: [distributorId], references: [id])

  @@unique([bidRequestId, distributorId])
  @@index([distributorId, status])
  @@index([bidRequestId, status])
  @@map("bid_responses")
}

model DistributorListing {
  id                  String   @id @default(uuid())
  distributorId       String

  catalogId           String?
  marca               String
  modelo              String
  dimension           String
  eje                 EjeType?
  tipo                String    @default("nueva")  // "nueva" | "reencauche"

  precioCop           Float
  precioPromo         Float?
  promoHasta          DateTime?
  incluyeIva          Boolean  @default(false)

  cantidadDisponible  Int      @default(0)
  tiempoEntrega       String?

  descripcion         String?  @db.Text
  imageUrls           Json?    // ["url1","url2",...] max 5
  coverIndex          Int      @default(0)  // which image is the cover
  imageQualityScore   Int      @default(0)   // 0-100, higher = better quality listing
  isActive            Boolean  @default(true)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  distributor         Company            @relation("DistributorListings", fields: [distributorId], references: [id])
  catalog             TireMasterCatalog? @relation(fields: [catalogId], references: [id])

  @@index([distributorId, isActive])
  @@index([dimension, isActive])
  @@index([marca, dimension, isActive])
  @@index([precioCop])
  @@index([isActive, createdAt])
  @@index([isActive, imageQualityScore, createdAt])
  @@index([isActive, precioCop])
  @@index([tipo, isActive])
  @@map("distributor_listings")

  reviews DistributorReview[]
  orders  MarketplaceOrder[]
}

model DistributorReview {
  id            String   @id @default(uuid())
  listingId     String
  userId        String
  rating        Int      // 1-5 stars
  comment       String?  @db.Text
  createdAt     DateTime @default(now())

  listing       DistributorListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user          User               @relation(fields: [userId], references: [id])

  @@unique([listingId, userId])  // one review per user per listing
  @@index([listingId])
  @@map("distributor_reviews")
}

model MarketplaceOrder {
  id              String   @id @default(uuid())
  listingId       String
  distributorId   String
  quantity        Int      @default(1)
  totalCop        Float

  // Buyer info (logged in user OR guest)
  userId          String?
  buyerName       String
  buyerEmail      String
  buyerPhone      String?
  buyerAddress    String?
  buyerCity       String?
  buyerCompany    String?

  // Status
  status          String   @default("pendiente")  // pendiente | confirmado | enviado | entregado | cancelado
  notas           String?  @db.Text

  // Payment
  paymentId       String?
  paymentStatus   String?  // approved | declined | error | voided | pending
  totalWithIva    Float?

  // Return request (initiated by buyer)
  returnRequestedAt DateTime?
  returnReason      String?  @db.Text
  returnStatus      String?  // pendiente | aprobada | rechazada
  returnResolvedAt  DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  listing         DistributorListing @relation(fields: [listingId], references: [id])
  distributor     Company            @relation("MarketplaceOrders", fields: [distributorId], references: [id])
  user            User?              @relation(fields: [userId], references: [id])

  @@index([distributorId, status])
  @@index([userId])
  @@index([buyerEmail])
  @@index([createdAt])
  @@index([listingId])
  @@map("marketplace_orders")
}

// =============================================================================
// PLATE CACHE — crowdsourced vehicle lookups
// =============================================================================

model PlateCache {
  id        String   @id @default(uuid())
  placa     String   @unique
  marca     String?
  linea     String?
  modelo    String?
  clase     String?
  servicio  String?
  source    String   @default("community") // runt, tirepro, community
  lookups   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([placa])
  @@map("plate_cache")
}

// =============================================================================
// BRAND INFO — editorial / scraped facts about each tire brand
// =============================================================================

model BrandInfo {
  id              String   @id @default(uuid())
  // Canonical brand name as stored on listings (case-insensitive lookup)
  name            String   @unique
  // URL-safe slug for /marketplace/brand/[slug]
  slug            String   @unique
  // Editorial fields (filled by the scraper script and/or manually)
  logoUrl         String?
  country         String?  // Country of origin
  headquarters    String?  // City, country
  foundedYear     Int?
  website         String?
  description     String?  @db.Text
  plants          Json?    // Array of { city, country }
  parentCompany   String?
  // Quality tier: 'premium' (Michelin, Bridgestone, etc.) | 'mid' (Hankook,
  // Yokohama…) | 'value' (everything else). Rendered on the brand page as
  // a star rating + label.
  tier            String?
  // Free-form extra facts the scraper picked up
  facts           Json?
  source          String?  // 'wikipedia', 'manual', 'scraped'
  sourceUrl       String?
  lastScrapedAt   DateTime?

  // ─── Admin-editable customization ────────────────────────────────────────
  // Overrides applied on the public brand page in the marketplace.
  primaryColor    String?  // hex like "#E30613" — hero/accents tint
  accentColor     String?  // hex — secondary color for badges/ctas
  heroImageUrl    String?  // optional background banner
  tagline         String?  // short marketing line under the brand name
  published       Boolean  @default(true) // hide unfinished brand pages
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@map("brand_info")
}

// =============================================================================
// BULK UPLOAD SNAPSHOT
// Keeps a 1-week rewindable record of each bulk-tire-upload so users can
// revert or edit-and-reapply before the data is considered "committed".
// Snapshots are invalidated the moment any of their tires gets an
// inspection or vida change — that signals someone already used the data
// and a blind revert would destroy real work.
// =============================================================================

model BulkUploadSnapshot {
  id                String    @id @default(uuid())
  companyId         String
  userId            String?    // FK to User; null for legacy uploads
  uploadedAt        DateTime  @default(now())
  expiresAt         DateTime  // uploadedAt + 7 days, computed at create time
  fileName          String?
  tireCount         Int       @default(0)
  tireIds           String[]
  rawRows           Json      // original Excel rows as parsed JSON — enables edit+reapply
  invalidated       Boolean   @default(false)
  invalidatedAt     DateTime?
  invalidatedReason String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, uploadedAt])
  @@index([expiresAt])
  @@map("bulk_upload_snapshots")
}
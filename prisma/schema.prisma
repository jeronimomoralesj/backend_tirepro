// =============================================================================
// NOTIFICATION
// =============================================================================

model Notification {
  id        String           @id @default(uuid())
  title     String
  message   String
  type      NotificationType
  seen      Boolean          @default(false)
  createdAt DateTime         @default(now())

  tireId    String?
  vehicleId String?
  companyId String?

  // What action resolves this notification
  actionType    String?   // 'rotate' | 'adjust_pressure' | 'retread' | 'replace' | 'inspect' | 'remove_from_service'
  actionPayload Json?     // { tireId, fromPosition?, toPosition?, targetPsi?, etc }
  actionLabel   String?   // "Rotar posición 1 ↔ 3" (human-readable)

  // Execution tracking
  executed      Boolean   @default(false)
  executedAt    DateTime?
  executedBy    String?   // userId or 'agent' or 'driver'

  // Driver notification tracking
  sentToDriver      Boolean   @default(false)
  sentToDriverAt    DateTime?
  driverConfirmed   Boolean   @default(false)
  driverConfirmedAt DateTime?

  // Grouping for UI
  groupKey   String?   // vehicleId for grouping by vehicle
  priority   Int       @default(0)  // higher = more urgent

  tire    Tire?    @relation(fields: [tireId], references: [id], onDelete: SetNull)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, seen])
  @@index([companyId, executed])
  @@index([companyId, priority])
  @@index([groupKey])
  @@index([vehicleId])
  @@index([tireId])
}


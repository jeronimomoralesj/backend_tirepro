  icono          String?
  excluirDeFlota Boolean             @default(false)
  orden          Int                 @default(0)
  // Semantic kind. `disponible` is user-managed; `reencauche` / `fin_de_vida`
  // are system-managed — there should be at most one of each per company,
  // enforced by the partial unique index below.
  tipo           InventoryBucketTipo @default(disponible)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tires   Tire[]

  @@unique([companyId, nombre])
  @@index([companyId])
  @@index([companyId, tipo])
  @@map("tire_inventory_buckets")

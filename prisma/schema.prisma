// =============================================================================
// TIREPRO — PRISMA SCHEMA
// =============================================================================
//
// MIGRATION SAFETY (800 live tires):
//   • All new columns are nullable — zero breaking changes to existing rows
//   • New tables have no required FKs that would block a deploy
//   • primeraVida and desechos JSON cols are KEPT as read-only legacy
//   • Run scripts/backfill-vida-snapshots.ts after deploying this schema
//
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  admin
  viewer
  technician
  // Distribuidor-only roles — see CatalogModule.
  //   catalogo:       access to SKU catalog (search, edit images, download PDFs)
  //   catalogo_admin: same + the downloads-stats dashboard
  // A distribuidor user with `admin` still has access to everything.
  catalogo
  catalogo_admin
}

enum CompanyPlan {
  marketplace
  plus
  pro
  distribuidor
}

enum TireAlertLevel {
  ok
  watch
  warning
  critical
}

enum EjeType {
  direccion
  traccion
  libre
  remolque
  repuesto
}

// Strongly-typed vida sequence — replaces magic strings in TireEvento.notas
enum VidaValue {
  nueva
  reencauche1
  reencauche2
  reencauche3
  fin
}

// Per-item lifecycle inside a PurchaseOrder. Each tire or line item travels
// through its own states — decoupled from the order-level status so a mixed
// order can partially progress (one reencauche item approved, another
// rejected) without the parent status becoming ambiguous.
enum PurchaseOrderItemStatus {
  pendiente // created; order not yet quoted or accepted
  cotizada // distributor has priced this line
  en_reencauche_bucket // deprecated (old flow); kept for historical data
  recogida_por_dist // reencauche only: dist physically collected the tire, awaiting reencauche decision
  aprobada // reencauche only: dist accepted; has ETA; tire vida will be incremented on entregar
  rechazada // reencauche only: dist rejected with motivo; tire routed to fin-de-vida
  devuelta // reencauche only: dist rejected but tire is still usable; returned to fleet's Disponible bucket
  entregada // reencauche only: tire handed back, moved to disponible bucket
  completada // llanta-nueva only: delivered to fleet
  cancelada
}

// Semantic kind of an inventory bucket. Non-disponible buckets are
// system-managed (one `reencauche` bucket auto-created per company on first
// use); users create/delete their own `disponible` buckets freely.
enum InventoryBucketTipo {
  disponible
  reencauche
  fin_de_vida
}

enum TireEventType {
  montaje
  rotacion
  reparacion
  retiro
  inspeccion
  reencauche
  regrabado
}

// Tire tread design — determines valid axle positions and wear expectations
enum TireDesignType {
  direccional
  traccion
  toda_posicion
  mixto
  regional
}

// How an inspection was created — critical for CV model training data quality:
// only 'computer_vision' rows should train the depth model;
// 'manual' rows are ground truth for accuracy measurement.
enum InspeccionSource {
  manual
  bulk_upload
  computer_vision
  api
}

enum NotificationType {
  info
  warning
  critical
}

enum BidRequestStatus {
  abierta
  cerrada
  adjudicada
  cancelada
}

enum BidResponseStatus {
  pendiente
  cotizada
  ganadora
  rechazada
  expirada
}

enum CouponCategory {
  llantas
  reencauches
  baterias
  gasolina
  aceites
}

// Operational state of a vehicle — drives orphan import from Merquepro.
// `fuera_de_operacion` = vehicle is preserved in TirePro but not linked to
// any fleet (companyId null), so historical analysis stays queryable.
enum VehicleOperationalState {
  activo
  fuera_de_operacion
}

// Team KPI targets — what gets counted and the cadence.
enum KpiMetric {
  vehicles_inspected
  clients_inspected
  tires_inspected
}

enum KpiPeriod {
  weekly
  monthly
  quarterly
  custom
}

// Why a vida ended — drives the recommendation engine
enum MotivoFinVida {
  reencauche // normal planned retread
  desgaste // worn to legal limit naturally
  dano_mecanico // cut, puncture, sidewall damage
  dano_operacional // overload, misuse, incorrect mounting
  accidente // road incident
  preventivo // removed before EOL as a fleet decision
  otro
}

// =============================================================================
// USER & AUTH
// =============================================================================

model User {
  id                String    @id @default(uuid())
  name              String
  email             String    @unique
  password          String
  companyId         String?
  role              UserRole  @default(admin)
  puntos            Int       @default(0)
  isVerified        Boolean   @default(false)
  verificationToken String?
  // Password reset
  resetToken        String?
  resetTokenExpiry  DateTime?
  preferredLanguage String    @default("es")
  userPlan          String    @default("free") // "free" | "plus" — for users without a company

  // Notification preferences — how this user wants to receive alerts
  notifChannel String? // 'email' | 'whatsapp' | 'none'  (null = not configured)
  notifContact String? // email address or phone number depending on channel

  // Easter egg
  saturnVUnlocked Boolean @default(false)

  // Login tracking — denormalized for fast "last active" lookups; detailed
  // per-session rows live in UserLoginLog for analytics.
  lastLoginAt DateTime?
  loginCount  Int       @default(0)
  // De-duplicated set of IPs this user has ever logged in from. Used for
  // anomaly detection ("new IP" alerts) and future security reviews.
  knownIps    String[]  @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company           Company?            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messages          Message[]
  incomes           Income[]
  vehicleAccess     UserVehicleAccess[]
  inspecciones      Inspeccion[] // inspections this user performed
  reviews           DistributorReview[]
  marketplaceOrders MarketplaceOrder[]
  loginLogs         UserLoginLog[]
  teamKpis          TeamKpi[]
  catalogDownloads  CatalogDownload[]

  @@index([companyId])
  @@index([email])
}

// Replaces User.plates[] string array — now queryable and relational
model UserVehicleAccess {
  userId    String
  vehicleId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@id([userId, vehicleId])
  @@index([userId])
  @@index([vehicleId])
  @@map("user_vehicle_access")
}

// One row per successful login — used for cohort / retention analysis in
// Metabase. Deliberately lightweight so we can keep every row forever.
model UserLoginLog {
  id        String   @id @default(uuid())
  userId    String
  fecha     DateTime @default(now())
  ip        String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, fecha])
  @@index([fecha])
  @@map("user_login_logs")
}

// =============================================================================
// COMPANY
// =============================================================================

model Company {
  id           String      @id @default(uuid())
  name         String
  periodicity  Int         @default(1)
  profileImage String      @default("https://tireproimages.s3.us-east-1.amazonaws.com/companyResources/logoFull.png")
  plan         CompanyPlan @default(pro)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Distributor-only fields
  emailAtencion String?
  telefono      String?
  descripcion   String? @db.Text
  bannerImage   String?
  direccion     String?
  ciudad        String?
  sitioWeb      String?
  cobertura     Json? // [{ciudad, direccion, lat, lng},...] — locations with coordinates
  tipoEntrega   String? // "domicilio" | "recogida" | "ambos"
  colorMarca    String? // hex color for map pins and branding

  // Agent automation configuration
  agentSettings Json @default("{\"agentEnabled\":false,\"alertMode\":\"display_only\",\"purchaseMode\":\"manual\"}")

  distributors        DistributorAccess[]   @relation("CompanyDistributors")
  clients             DistributorAccess[]   @relation("DistributorClients")
  users               User[]
  vehicles            Vehicle[]
  tires               Tire[]
  notifications       Notification[]
  snapshots           CompanySnapshot[]
  vidaSnapshots       TireVidaSnapshot[]
  recommendations     TireRecommendation[]
  tireHistory         VehicleTireHistory[]
  inventoryBuckets    TireInventoryBucket[]
  bulkUploadSnapshots BulkUploadSnapshot[]
  orders              PurchaseOrder[]       @relation("CompanyOrders")
  receivedOrders      PurchaseOrder[]       @relation("DistributorOrders")
  teamKpis            TeamKpi[]

  // Marketplace
  bidRequests       BidRequest[]         @relation("CompanyBidRequests")
  wonBids           BidRequest[]         @relation("WonBids")
  bidInvitations    BidInvitation[]      @relation("BidInvitations")
  bidResponses      BidResponse[]        @relation("BidResponses")
  listings          DistributorListing[] @relation("DistributorListings")
  marketplaceOrders MarketplaceOrder[]   @relation("MarketplaceOrders")

  // Catalog — per-distributor SKU photos + per-download events
  catalogImages    CatalogImage[]
  catalogDownloads CatalogDownload[]
  catalogVideos    CatalogVideo[]

  @@index([plan])
}

model DistributorAccess {
  companyId     String
  distributorId String
  createdAt     DateTime @default(now())

  company     Company @relation("CompanyDistributors", fields: [companyId], references: [id])
  distributor Company @relation("DistributorClients", fields: [distributorId], references: [id])

  @@id([companyId, distributorId])
  @@index([distributorId])
}

// =============================================================================
// VEHICLE
// =============================================================================

model Vehicle {
  id                String  @id @default(uuid())
  placa             String
  kilometrajeActual Int     @default(0)
  carga             String
  pesoCarga         Float
  tipovhc           String
  // Nullable: when a vehicle is imported as "fuera de operación" we keep
  // the full record + tire history in TirePro but don't link it to any
  // fleet. Every company-scoped query (where companyId = X) naturally
  // excludes orphans since NULL never matches.
  companyId         String?
  cliente           String?

  // Vehicle make / manufacturer (Kenworth, Volvo, International…)
  marca String?

  // User-declared expected km per month at onboarding. Stays fixed once set
  // so we can compare it against the real observed value below.
  kmMensualEstimado Int?

  // Real average km/month derived from inspections / kilometrajeActual
  // history. Recomputed by refreshVehicleKmMensual on every odometer update.
  kmMensualReal Float?

  // NUEVO 🔽
  tipoOperacion String? // formato: "90-10" (pavimento-trocha)

  // NUEVO 🔽
  configuracion String? // formato: "4-4", "6-4", "2-2-2"

  union                 Json @default("[]")
  presionesRecomendadas Json @default("[]")

  // ─── External system dedup key ───────────────────────────────────────────
  // Populated by integrators (e.g. MERQUEPRO migration) so re-running an
  // import doesn't duplicate rows. Null for anything created natively.
  externalSourceId String? @unique

  // ─── Archival ────────────────────────────────────────────────────────────
  // Set when a vehicle hasn't been inspected in ≥ 1 year (triggered by the
  // cleanup job). Archived vehicles stay in the DB so we can reconnect them
  // later, but are filtered from every company-scoped query by default.
  archivedAt DateTime?

  // ─── Operational state ──────────────────────────────────────────────────
  // `fuera_de_operacion` vehicles are orphaned (companyId null) during
  // import but keep the full record for long-horizon analysis.
  estadoOperacional     VehicleOperationalState @default(activo)
  fueraDeOperacionDesde DateTime?
  // Intended fleet name (preserved when orphaned so we know the origin).
  originalClient        String?
  // Vehicle-level activity signal carried over from Merquepro. Source of
  // truth for the importer; our computed `kmMensualReal` is derived later.
  kmMensualMerquepro    Float?
  ultimaActividadAt     DateTime?
  // Lossless catch-all: anything from the source feed we don't promote to
  // a first-class column lands here so no data is ever dropped on import.
  sourceMetadata        Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company            Company?             @relation(fields: [companyId], references: [id], onDelete: SetNull)
  tires              Tire[]               @relation("VehicleTires")
  extras             Extra[]
  notifications      Notification[]
  userAccess         UserVehicleAccess[]
  vehicleInspections VehicleInspection[]
  drivers            VehicleDriver[]
  tireHistory        VehicleTireHistory[]

  @@unique([companyId, placa])
  @@index([companyId])
  @@index([placa])
  @@index([companyId, archivedAt])
  @@index([estadoOperacional])
  // NUEVOS ÍNDICES 🔽
  @@index([tipoOperacion])
  @@index([configuracion])
}

// =============================================================================
// VEHICLE DRIVER
// Up to 3 drivers per vehicle — used for messaging when tire issues are detected.
// =============================================================================

model VehicleDriver {
  id        String   @id @default(uuid())
  vehicleId String
  nombre    String
  telefono  String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("vehicle_drivers")
}

// =============================================================================
// VEHICLE INSPECTION
// Periodic full-vehicle health record.
// Correlates vehicle condition (alignment, brakes, load) with tire wear patterns.
// Feeds ML: bad alignment → irregular tread wear; overload → accelerated CPK.
// =============================================================================

model VehicleInspection {
  id           String   @id @default(uuid())
  vehicleId    String
  fecha        DateTime
  realizadoPor String? // userId or free-text technician name

  kmActual            Int?
  presionPromedioPsi  Float? // average pressure across all tires at inspection
  tiresInspeccionadas Int? // how many tires were measured this visit

  // Vehicle condition flags — nullable: absent means not checked, not OK
  alineacionOk    Boolean?
  balanceoOk      Boolean?
  freinosOk       Boolean?
  suspensionOk    Boolean?
  cargaConformeKg Float? // actual load at inspection time (kg)

  notas     String?
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, fecha])
  @@map("vehicle_inspections")
}

// =============================================================================
// TIRE — Core entity
// =============================================================================

model Tire {
  id        String  @id @default(uuid())
  // Nullable: mirrors Vehicle.companyId. A tire mounted on an orphaned
  // vehicle is itself orphan so it never surfaces in any fleet dashboard.
  companyId String?
  vehicleId String?
  placa     String // tire serial / identifier

  // Identity
  marca              String
  diseno             String
  dimension          String
  eje                EjeType
  tipoDiseno         TireDesignType? // tread design (direccional/traccion/toda_posicion/mixto/regional)
  posicion           Int             @default(0)
  profundidadInicial Float

  // Dual (gemela) tire pairing — for twin configurations on the same axle side
  dualPartnerId String? // FK to the paired tire (mutual relationship)

  // Regrooving eligibility
  isRegrabable Boolean @default(false)

  // Current vida state — denormalized from TireEvento for fast reads
  vidaActual VidaValue @default(nueva)
  totalVidas Int       @default(0) // number of completed vida phases

  // Lifecycle accumulators
  fechaInstalacion     DateTime?
  diasAcumulados       Int       @default(0)
  kilometrosRecorridos Int       @default(0)

  // -------------------------------------------------------------------------
  // CACHED ANALYTICS — recomputed by refreshTireAnalyticsCache on every write.
  // Dashboard reads are O(1). Never recompute on the read path.
  // -------------------------------------------------------------------------
  currentCpk           Float? // current-life CPK = costVidaActual / kmVidaActual
  lifetimeCpk          Float? // lifetime CPK = sumCosts_allVidas / sumKm_allVidas
  // Use this for company-wide / cross-vida metrics.
  currentCpt           Float?
  currentProfundidad   Float? // latest avg tread depth ((Int+Cen+Ext) / 3)
  currentPresionPsi    Float? // latest recorded pressure
  cpkTrend             Float? // linear regression slope over last 5 inspections
  // negative = improving, positive = degrading
  projectedKmRemaining Int?
  projectedDateEOL     DateTime?
  healthScore          Int? // 0–100 composite (depth 50%, trend 30%, irregularity 20%)
  alertLevel           TireAlertLevel @default(ok)
  lastInspeccionDate   DateTime?

  // ── Projected state (updated daily by cron, never by inspections) ────────
  // These estimate the tire's CURRENT condition based on degradation rate.
  // Inspections overwrite these on every write.
  projectedProfundidad    Float?
  projectedAlertLevel     TireAlertLevel?
  projectedHealthScore    Int?
  projectedDaysToLimit    Int?
  degradationRateMmPerDay Float?
  projectionUpdatedAt     DateTime?

  // -------------------------------------------------------------------------
  // LEGACY JSON — kept read-only after backfill migration. Do not write here.
  // primeraVida: superseded by TireVidaSnapshot
  // desechos:    superseded by TireVidaSnapshot (motivoFin = fin)
  // -------------------------------------------------------------------------
  primeraVida Json  @default("[]") // @deprecated
  desechos    Json? // @deprecated

  inventoryTag      String?
  inventoryBucketId String?
  inventoryBucket   TireInventoryBucket? @relation(fields: [inventoryBucketId], references: [id])

  lastVehicleId      String?
  lastVehiclePlaca   String?
  lastPosicion       Int?
  inventoryEnteredAt DateTime?

  // External system dedup key — same contract as Vehicle.externalSourceId.
  externalSourceId String? @unique

  // Original fleet name (preserved when orphaned so origin is never lost).
  originalClient String?
  // Lossless catch-all for non-promoted source fields (cpkStad, mileageStad,
  // hasTraceability, etc.) so no data is dropped on import.
  sourceMetadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company         Company?             @relation(fields: [companyId], references: [id], onDelete: SetNull)
  vehicle         Vehicle?             @relation("VehicleTires", fields: [vehicleId], references: [id])
  inspecciones    Inspeccion[]
  eventos         TireEvento[]
  costos          TireCosto[]
  notifications   Notification[]
  vidaSnapshots   TireVidaSnapshot[]
  recommendations TireRecommendation[]
  historyEntries  VehicleTireHistory[]
  orderItems      PurchaseOrderItem[]  @relation("PurchaseOrderItems")

  @@index([companyId])
  @@index([vehicleId])
  @@index([marca, dimension])
  @@index([alertLevel])
  @@index([companyId, alertLevel])
  @@index([companyId, lastInspeccionDate])
  @@index([companyId, vidaActual]) // fleet breakdown by vida phase
  @@index([dimension, marca]) // cross-fleet benchmark queries
  @@index([companyId, inventoryBucketId])
  @@index([companyId, inventoryEnteredAt])
}

// =============================================================================
// INSPECCION
// Every field that could correlate with wear rate or serve as a CV model
// feature must be a first-class column here — not buried in JSON.
// =============================================================================

model Inspeccion {
  id     String   @id @default(uuid())
  tireId String
  fecha  DateTime

  // ── Tread depth readings (mm) ─────────────────────────────────────────────
  profundidadInt Float
  profundidadCen Float
  profundidadExt Float

  // ── Pressure readings — nullable: not always measured ─────────────────────
  // Under-inflation is the #1 cause of premature wear on Colombian heavy fleets.
  // presionDelta is computed at write time (negative = under-inflated).
  // presionRecomendadaPsi is auto-filled from vehicle.presionesRecomendadas
  // at write time — technicians don't need to know the spec.
  presionPsi            Float? // measured tire pressure (PSI)
  presionRecomendadaPsi Float? // target pressure for this position/load
  presionDelta          Float? // presionPsi - presionRecomendadaPsi (computed on write)

  // ── Vida phase at this inspection ─────────────────────────────────────────
  // Denormalized for O(1) analytics slicing without joining TireEvento.
  // Enables: "avg CPK of Michelin XDE2 in reencauche1" in a single indexed query.
  vidaAlMomento VidaValue @default(nueva)

  // ── Computed metrics (stored for fleet-wide aggregation) ──────────────────
  cpk                 Float? // current-life CPK: costVidaActual / kmVidaActual
  lifetimeCpk         Float? // lifetime CPK: sumAllCosts / sumAllVidaKm — used
  // for company-wide metrics that average across tires
  cpkProyectado       Float?
  cpt                 Float?
  cptProyectado       Float?
  diasEnUso           Int?
  mesesEnUso          Float?
  kilometrosEstimados Int?
  kmActualVehiculo    Int? // vehicle odometer at inspection
  kmEfectivos         Int? // km used for CPK calculation
  kmProyectado        Float? // projected km to legal limit

  // ── Image and provenance ──────────────────────────────────────────────────
  // imageUrl is kept for legacy reads only. New writes populate imageUrls
  // (up to 2 photos per tire). UI reads imageUrls ?? [imageUrl] for older
  // rows that never got migrated.
  imageUrl  String?
  imageUrls String[]         @default([])
  source    InspeccionSource @default(manual)

  // ── Computer vision model output fields ───────────────────────────────────
  // Stored alongside the human measurement so model accuracy is trackable
  // over time as the CV model is retrained and improved.
  cvProfundidadInt Float? // model-predicted depth, interior zone (mm)
  cvProfundidadCen Float? // model-predicted depth, center zone (mm)
  cvProfundidadExt Float? // model-predicted depth, exterior zone (mm)
  cvConfidence     Float? // model confidence 0–1
  cvModelVersion   String? // which model version produced this prediction

  // ── Who performed this inspection ─────────────────────────────────────────
  inspeccionadoPorId     String? // FK to User (null for bulk uploads)
  inspeccionadoPorNombre String? // free-text fallback when no user account

  // External system dedup key — populated by integrations.
  externalSourceId String? @unique

  // Lossless catch-all for per-inspection source fields (alert, operationType,
  // owner/driver, consecutives, report IDs) so nothing is ever dropped.
  sourceMetadata Json?

  createdAt DateTime @default(now())

  tire             Tire  @relation(fields: [tireId], references: [id], onDelete: Cascade)
  inspeccionadoPor User? @relation(fields: [inspeccionadoPorId], references: [id])

  @@index([tireId])
  @@index([fecha])
  @@index([cpk])
  @@index([tireId, fecha])
  @@index([tireId, createdAt])
  @@index([vidaAlMomento]) // fleet analytics by vida phase
  @@index([tireId, vidaAlMomento]) // per-tire per-vida history
  @@index([source]) // CV training data extraction
  @@index([presionPsi]) // pressure correlation queries
  @@index([inspeccionadoPorId])
  @@map("inspecciones")
}

// =============================================================================
// TIRE VIDA SNAPSHOT
// One row per completed vida phase (nueva → reencauche1 → reencauche2 → fin).
// Written by updateVida every time a vida transition occurs.
//
// This is TirePro's primary ML training asset and the backbone for:
//   • "Retread or replace?" recommendation engine
//   • TireBenchmark nightly aggregation (brand/dimension performance)
//   • Per-company fleet intelligence and TCO reports
//   • Retread ROI calculation
//
// dataSource = 'backfill' marks rows from the migration script so ML pipelines
// can apply appropriate data-quality filters.
// =============================================================================

model TireVidaSnapshot {
  id        String  @id @default(uuid())
  tireId    String
  // Nullable for parity with Tire.companyId — snapshots on orphan tires
  // keep their historical payload without faking a company link.
  companyId String? // denormalized for fleet-wide aggregation without joining Tire

  vida VidaValue // which vida phase this snapshot covers

  // ── Tire identity at the start of this vida ───────────────────────────────
  // Stored here because the tire may be updated later; we need the exact
  // state that produced these metrics.
  marca     String
  diseno    String
  dimension String
  eje       EjeType
  posicion  Int?

  // Retread-specific identity — only for reencauche* vidas
  bandaNombre String? // retread band name
  bandaMarca  String? // retread band brand (may differ from carcass brand)
  proveedor   String? // retread shop or supplier

  // ── Financial ─────────────────────────────────────────────────────────────
  costoInicial Float // cost of this vida (new tire price or retread cost)
  costoTotal   Float // sum of all TireCosto entries during this vida

  // ── Duration ──────────────────────────────────────────────────────────────
  fechaInicio  DateTime
  fechaFin     DateTime
  diasTotales  Int
  mesesTotales Float

  // ── Wear metrics ──────────────────────────────────────────────────────────
  profundidadInicial     Float
  profundidadFinal       Float
  mmDesgastados          Float
  mmDesgastadosPorMes    Float?
  mmDesgastadosPor1000km Float?

  // Per-zone final depths — center > edges = over-inflation; edges > center = under-inflation
  profundidadIntFinal Float?
  profundidadCenFinal Float?
  profundidadExtFinal Float?
  desgasteIrregular   Boolean @default(false) // true if max zone delta > 3mm at end

  // ── Distance ──────────────────────────────────────────────────────────────
  kmTotales         Int
  kmProyectadoFinal Float?

  // ── CPK / CPT performance ─────────────────────────────────────────────────
  // Min/max/avg across all inspections in this vida — not just the final value.
  // Enables detection of performance inflection points for ML training.
  cpkFinal           Float?
  cptFinal           Float?
  cpkProyectadoFinal Float?
  cptProyectadoFinal Float?
  cpkMin             Float?
  cpkMax             Float?
  cpkAvg             Float?

  // ── Pressure summary ──────────────────────────────────────────────────────
  presionAvgPsi          Float?
  presionMinPsi          Float?
  presionMaxPsi          Float?
  inspeccionesConPresion Int    @default(0)

  // ── Health at retirement ──────────────────────────────────────────────────
  healthScoreAtEnd Int?
  alertLevelAtEnd  TireAlertLevel?

  // ── Inspection history anchors ────────────────────────────────────────────
  totalInspecciones Int     @default(0)
  firstInspeccionId String?
  lastInspeccionId  String?

  // ── Why this vida ended ───────────────────────────────────────────────────
  motivoFin   MotivoFinVida?
  notasRetiro String?

  // Desecho fields — only when motivoFin != reencauche (tire scrapped)
  desechoCausales   String?
  desechoMilimetros Float? // mm remaining when scrapped
  desechoRemanente  Float? // estimated value lost: cpk × kmPerMm × mmRemaining
  desechoImageUrls  String[] @default([])

  // 'live' = created by updateVida | 'backfill' = created by migration script
  dataSource String @default("live")

  createdAt DateTime @default(now())

  tire    Tire     @relation(fields: [tireId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([tireId])
  @@index([tireId, vida])
  @@index([companyId])
  @@index([companyId, vida])
  @@index([companyId, marca, dimension])
  @@index([companyId, eje])
  @@index([cpkFinal])
  @@index([dimension, marca, vida])
  @@index([dataSource])
  @@map("tire_vida_snapshots")
}

// =============================================================================
// TIRE BENCHMARK
// Aggregated performance data by (marca, diseno, dimension).
// Populated nightly from TireVidaSnapshot.
//
// retreadRoiRatio = cpkReencauche1 / cpkNueva
//   < 1.0 = retreading achieves lower cost per km than buying new (pays off)
//   > 1.0 = retreading is more expensive per km (consider replacing)
// =============================================================================

model TireBenchmark {
  id        String @id @default(uuid())
  marca     String
  diseno    String
  dimension String

  sampleSize   Int
  companyCount Int @default(1)

  precioPromedio Float?
  precioMin      Float?
  precioMax      Float?

  avgCpk               Float?
  medianCpk            Float?
  avgCpt               Float?
  avgKmPorVida         Float?
  avgMmDesgaste        Float?
  avgDesgastePor1000km Float?

  cpkNueva          Float?
  cpkReencauche1    Float?
  cpkReencauche2    Float?
  sampleNueva       Int    @default(0)
  sampleReencauche1 Int    @default(0)
  sampleReencauche2 Int    @default(0)

  retreadRoiRatio Float?

  // Pressure correlation (populated when enough data exists)
  cpkAtOptimalPsi     Float? // CPK when pressure within ±5 PSI of recommended
  cpkAtLowPsi         Float? // CPK when pressure >10 PSI below recommended
  pressureSensitivity Float? // % CPK degradation per 10 PSI under-inflation

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([marca, diseno, dimension])
  @@index([marca, dimension])
  @@index([dimension])
  @@index([retreadRoiRatio])
  @@map("tire_benchmarks")
}

// =============================================================================
// VEHICLE TIRE HISTORY
// Immutable log of every tire that's been mounted on a given vehicle +
// position. One row per (tire, vehicle, position, mount) tuple; closed out
// when the tire is removed / reencauched / scrapped. Drives recommendations
// like "this vehicle's position 1 has typically run Continental HDR2 with
// avg CPK 48 and 110k km per vida — consider the same again."
//
// Open entry: fechaDesmonte IS NULL  (tire currently at this position)
// Closed entry: fechaDesmonte NOT NULL + motivoDesmonte set
// =============================================================================
model VehicleTireHistory {
  id String @id @default(uuid())

  // Who + where
  vehicleId String
  // Nullable when the host vehicle was imported as orphan (fuera de operación).
  // History is still written so per-position analytics survive orphaning.
  companyId String?
  position  Int

  // What tire — keep an FK to Tire when it still exists, but also snapshot the
  // identity fields so history survives tire deletion / re-import.
  tireId        String?
  marca         String
  diseno        String
  dimension     String
  vidaAlMontaje VidaValue @default(nueva) // tire's vida when it was mounted here

  // Lifecycle
  fechaMontaje   DateTime  @default(now())
  fechaDesmonte  DateTime?
  // 'rotacion'   — moved to a different position on same (or another) vehicle
  // 'reencauche' — vida transition (nueva → reencauche1, etc)
  // 'fin'        — scrapped / end of life
  // 'desvinculado' — tire unassigned from vehicle (inventory)
  // 'vehiculo_archivado' — host vehicle was archived
  motivoDesmonte String?

  // Performance snapshot at desmonte — fed by the desmonte hook, not written
  // on mount. Lets recommendations compare per-position CPK across brands.
  kmRecorridosAlDesmonte Int?
  cpkFinal               Float?
  profundidadInicial     Float?
  profundidadFinalMin    Float?

  // Free-form note (driver comments, mechanic notes, etc.)
  notas String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  tire    Tire?    @relation(fields: [tireId], references: [id], onDelete: SetNull)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([vehicleId, position])
  @@index([vehicleId, fechaDesmonte]) // pull current (open) entries per vehicle
  @@index([companyId])
  @@index([tireId])
  @@index([marca, diseno, dimension]) // per-SKU performance aggregation
  @@map("vehicle_tire_history")
}

// =============================================================================
// TIRE RECOMMENDATION
// Async-generated recommendations — decouples generation from reads.
// Enables A/B testing of rule-based vs ML model versions.
// =============================================================================

model TireRecommendation {
  id        String  @id @default(uuid())
  tireId    String?
  companyId String

  // 'replace_now' | 'retread' | 'pressure_adjust' | 'rotate' | 'buy_brand'
  tipo      String
  prioridad Int     @default(0) // 0 = info, 1 = watch, 2 = urgent, 3 = critical
  titulo    String
  cuerpo    String
  accion    String?

  // Machine-readable context for UI rendering without text parsing
  // e.g. { brandSuggested, estimatedSaving, currentCpk, benchmarkCpk,
  //         presionActual, presionRecomendada }
  metaData Json @default("{}")

  modelVersion String? // 'rule_v1' | 'ml_v2' etc.
  confidence   Float? // 0–1

  visto      Boolean   @default(false)
  descartado Boolean   @default(false)
  expiresAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tire    Tire?   @relation(fields: [tireId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, visto])
  @@index([companyId, prioridad])
  @@index([tireId])
  @@index([tipo])
  @@index([expiresAt])
  @@map("tire_recommendations")
}

// =============================================================================
// PURCHASE ORDER
// Fleet → Distributor solicitud/cotización workflow.
// =============================================================================

model PurchaseOrder {
  id            String @id @default(uuid())
  companyId     String
  distributorId String
  status        String @default("solicitud_enviada")
  // solicitud_enviada | cotizacion_recibida | aceptada | rechazada | completada
  // Order-level status is now a coarse summary; per-line state lives on
  // PurchaseOrderItem.status (see PurchaseOrderItemStatus).

  totalEstimado Float?
  notas         String?

  totalCotizado   Float?
  cotizacionFecha DateTime?
  cotizacionNotas String?

  // Pickup — scheduled by the dist after the fleet accepts. The pickup
  // moment is when tires physically leave the vehicles; every per-item
  // decision (reencauchar / devolver / fin de vida) happens at this step.
  pickupDate DateTime?

  resolvedAt DateTime?
  resolvedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company     Company             @relation("CompanyOrders", fields: [companyId], references: [id])
  distributor Company             @relation("DistributorOrders", fields: [distributorId], references: [id])
  items       PurchaseOrderItem[]

  @@index([companyId, status])
  @@index([distributorId, status])
  @@index([createdAt])
  @@map("purchase_orders")
}

// Per-tire / per-line row for a PurchaseOrder. Replaces the old JSON
// `items` + `cotizacion` blobs. Holds both the request spec (marca,
// dimension, cantidad…) and the per-line pricing + lifecycle state so
// partial progression through a mixed order is trackable without
// mutating a shared JSON.
model PurchaseOrderItem {
  id              String @id @default(uuid())
  purchaseOrderId String

  // For reencauche items, the specific tire being retread; nueva items
  // leave this null until the dist links delivered tires (if ever).
  tireId String?

  tipo         String // 'nueva' | 'reencauche'
  marca        String
  modelo       String? // banda recomendada (reencauche) | tread design (nueva)
  dimension    String
  eje          String?
  cantidad     Int     @default(1)
  vehiclePlaca String?
  urgency      String?
  notas        String?

  // Quote fields — filled by dist at cotizacion time
  precioUnitario           Float?
  disponible               Boolean? // true: in stock; false: backorder
  tiempoEntrega            String?
  cotizacionNotas          String?
  // Reencauche offer — a banda has a brand (Michelin, Bridgestone…) AND a
  // model/type (XDR, M700…). Both are captured at cotización time so the
  // fleet can decide on both axes and the entregar step pre-fills from them.
  // Null on nueva items. Profundidad inicial (mm) is the thickness the
  // banda will provide once installed — captured here so the EntregarModal
  // can seed the vida snapshot with the exact value the dist committed to.
  bandaOfrecidaMarca       String?
  bandaOfrecidaModelo      String?
  bandaOfrecidaProfundidad Float?

  // Lifecycle
  status            PurchaseOrderItemStatus @default(pendiente)
  estimatedDelivery DateTime? // dist ETA after approving reencauche
  motivoRechazo     String? // reason dist rejected reencauche (stored alongside the fin-de-vida snapshot)
  finalizedAt       DateTime? // when item reached entregada/rechazada/completada

  // Reencauche vida trail — snapshot before/after the retread cycle
  vidaPrevia VidaValue?
  vidaNueva  VidaValue?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  tire          Tire?         @relation("PurchaseOrderItems", fields: [tireId], references: [id], onDelete: SetNull)

  @@index([purchaseOrderId])
  @@index([tireId])
  @@index([status])
  // Accelerates "does this tire have an active reencauche cycle?" lookups
  // without hitting the legacy full-scan on the items JSON.
  @@index([tireId, status])
  @@map("purchase_order_items")
}

// =============================================================================
// TIRE EVENTO
// =============================================================================

model TireEvento {
  id       String        @id @default(uuid())
  tireId   String
  tipo     TireEventType
  fecha    DateTime
